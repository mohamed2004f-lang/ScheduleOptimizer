# ============================================
# ملف متغيرات البيئة - ScheduleOptimizer
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env

# ============================================
# إعدادات المصادقة (إلزامية)
# ============================================
ADMIN_USERNAME=admin-mohamed
ADMIN_PASSWORD=

# ============================================
# إعدادات Flask
# ============================================
SECRET_KEY=
FLASK_ENV=development
FLASK_DEBUG=0
# تلميحات تقنية في الواجهة (phase0، أعمدة DB) — افتراضياً = FLASK_DEBUG
# SHOW_DEV_HINTS=0

# ============================================
# قاعدة البيانات — PostgreSQL فقط
# ============================================
# إلزامي. التطبيق لا يعمل على SQLite في التشغيل العادي.
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/schedule_optimizer

# مسار pg_dump (اختياري — إن لم يكن في PATH)
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe

# نسخ احتياطي تلقائي على القرص D: (scripts\backup_full_to_d.ps1)
# BACKUP_MIRROR_ROOT=D:\ScheduleOptimizer_Backups
# BACKUP_RETENTION_DAYS=30

# Docker Compose: POSTGRES_PASSWORD (انظر docker-compose.yml)
# POSTGRES_PASSWORD=

# ============================================
# إعدادات الأمان
# ============================================
# SESSION_LIFETIME_MINUTES=60
# LOGIN_RATE_LIMIT_MAX=20
# LOGIN_RATE_LIMIT_WINDOW=60
# ENABLE_CSP=1
# ENABLE_ADMIN_STATUS_PAGE=1
# ENABLE_SYSTEM_DOCS_PAGE=0

# ============================================
# التسجيل وربط الخطة الأكاديمية
# ============================================
# off | warn | enforce — الافتراضي warn (تحذير فقط)
REG_PROGRAM_COURSE_MODE=warn

# ============================================
# ملاحظات:
# ============================================
# 1. لا ترفع ملف .env على GitHub أبداً!
# 2. ADMIN_PASSWORD و SECRET_KEY إلزاميتان
# 3. نسخ احتياطي PostgreSQL: python scripts/pg_dump_via_env.py
