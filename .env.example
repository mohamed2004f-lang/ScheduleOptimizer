# ============================================
# ملف متغيرات البيئة - ScheduleOptimizer
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env

# ============================================
# إعدادات المصادقة (إلزامية)
# ============================================
# ⚠️ يجب تعيين ADMIN_PASSWORD قبل تشغيل التطبيق — لن يعمل بدونها!
# تُستخدم فقط كـ bootstrap عند أول تشغيل (جدول users فارغ).
# بعد إنشاء المستخدمين في قاعدة البيانات، تصبح كلمات المرور مخزنة في جدول users.
ADMIN_USERNAME=admin-mohamed
ADMIN_PASSWORD=

# ============================================
# إعدادات Flask
# ============================================
# ⚠️ يجب تعيين SECRET_KEY ثابت في بيئة الإنتاج!
# لتوليد مفتاح آمن:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
FLASK_ENV=development
# وضع التصحيح معطّل افتراضياً لأسباب أمنية. فعّله فقط أثناء التطوير المحلي.
FLASK_DEBUG=0

# تشخيص اختياري: في صفحة «إدارة المستخدمين» يظهر مسار PostgreSQL وملف mechanical.db
# لمسؤول النظام (admin_main) فقط عند القيمة 1 أو true. افتراضياً معطّل — نص موجز للجميع.
# SHOW_USER_LIST_STORAGE_DIAGNOSTICS=0
# خيار اختياري (PostgreSQL): فرض uniqueness على username بدون حساسية لحالة الأحرف.
# انتبه: إذا كانت لديك حسابات قديمة مثل UserA و usera معاً، سيفشل إنشاء الفهرس حتى يتم تنظيفها.
# ENABLE_USERS_LOWER_UNIQUE_IDX=0

# ============================================
# إعدادات قاعدة البيانات
# ============================================
# خيار موحّد مفضّل: استخدم DATABASE_URL
# للتطوير (SQLite):
# DATABASE_URL=sqlite:///backend/database/mechanical.db
# للإنتاج (PostgreSQL) — لـ Alembic وسكربت scripts/migrate_sqlite_to_postgres.py
# DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/schedule_optimizer
DATABASE_URL=sqlite:///backend/database/mechanical.db

# خيار قديم (يبقى للتوافق الخلفي)
DATABASE_PATH=backend/database/mechanical.db

# مسار اختياري لملف SQLite عند نقل البيانات إلى Postgres (إن اختلف عن DATABASE_PATH)
# SQLITE_MIGRATION_SOURCE=backend/database/mechanical.db

# ============================================
# إعدادات الأمان
# ============================================
# مدة صلاحية الجلسة بالدقائق
SESSION_LIFETIME_MINUTES=60

# صفحة "إصدار المشروع وآخر تحديث" مفعّلة افتراضياً
# للتعطيل: 0
ENABLE_ADMIN_STATUS_PAGE=1

# تعطيل صفحة "توثيق النظام" افتراضياً (أمني)
# للتفعيل المؤقت: 1
ENABLE_SYSTEM_DOCS_PAGE=0

# ============================================
# ملاحظات:
# ============================================
# 1. لا ترفع ملف .env على GitHub أبداً!
# 2. استخدم كلمة مرور قوية في بيئة الإنتاج
# 3. ADMIN_PASSWORD و SECRET_KEY إلزاميتان — التطبيق لن يعمل بدونهما
# 4. لتوليد SECRET_KEY آمن، استخدم:
#    python -c "import secrets; print(secrets.token_hex(32))"
