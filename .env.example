# ============================================
# ملف متغيرات البيئة - ScheduleOptimizer
# ============================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env

# ============================================
# إعدادات المصادقة
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ============================================
# إعدادات Flask
# ============================================
SECRET_KEY=your_secret_key_here_generate_with_python_secrets
FLASK_ENV=development
FLASK_DEBUG=1

# ============================================
# إعدادات قاعدة البيانات
# ============================================
DATABASE_PATH=backend/database/mechanical.db

# ============================================
# إعدادات الأمان
# ============================================
# مدة صلاحية الجلسة بالدقائق
SESSION_LIFETIME_MINUTES=60

# ============================================
# ملاحظات:
# ============================================
# 1. لا ترفع ملف .env على GitHub أبداً!
# 2. استخدم كلمة مرور قوية في بيئة الإنتاج
# 3. لتوليد SECRET_KEY آمن، استخدم:
#    python -c "import secrets; print(secrets.token_hex(32))"
